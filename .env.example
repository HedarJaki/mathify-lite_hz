# ============================================================================
# Midtrans payment credentials — template.
# Copy this file to `.env` and fill in your own keys from the Midtrans
# dashboard (Settings -> Access Keys). `.env` is gitignored.
#
# Read at runtime by com.mathify.util.MidtransConfig. Real OS environment
# variables of the same name take precedence over this file.
# ============================================================================

MIDTRANS_MERCHANT_ID=your-merchant-id
MIDTRANS_CLIENT_KEY=Mid-client-xxxxxxxxxxxxxxxx
MIDTRANS_SERVER_KEY=Mid-server-xxxxxxxxxxxxxxxx

# false = sandbox (app.sandbox.midtrans.com), true = production
MIDTRANS_IS_PRODUCTION=false

# Premium plan price charged via Snap, in IDR (whole rupiah, no decimals)
MIDTRANS_PREMIUM_PRICE=49000
